APP_ENV=dev
SERVICE_VERSION=0.1.0
MCP_ENABLE_DEBUG_TOOLS=false
MCP_AUTH_TOKEN=
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,*.trycloudflare.com
N8N_WEBHOOK_BEARER_TOKEN=n8n-bearer-token

CONTACT_CONTEXT_WEBHOOK_URL=
CONTACT_CONTEXT_TIMEOUT_SECONDS=5

APPOINTMENT_AVAILABILITY_WEBHOOK_URL=http://host.docker.internal:5680/webhook-test/sa-appointment-availability
APPOINTMENT_AVAILABILITY_TIMEOUT_SECONDS=8

APPOINTMENT_EVENTS_WEBHOOK_URL=
APPOINTMENT_EVENTS_TIMEOUT_SECONDS=8

APPOINTMENT_CONFIRM_WEBHOOK_URL=http://host.docker.internal:5680/webhook/sa-appointment-confirm
APPOINTMENT_CONFIRM_TIMEOUT_SECONDS=8

APPOINTMENT_RESCHEDULE_WEBHOOK_URL=http://host.docker.internal:5680/webhook/sa-appointment-reschedule
APPOINTMENT_RESCHEDULE_TIMEOUT_SECONDS=8

APPOINTMENT_CANCEL_WEBHOOK_URL=http://host.docker.internal:5680/webhook/sa-appointment-cancel
APPOINTMENT_CANCEL_TIMEOUT_SECONDS=8

APPOINTMENT_BOOKING_INVITATION_WEBHOOK_URL=http://host.docker.internal:5680/webhook/sa-appointment-booking-invitation
APPOINTMENT_BOOKING_INVITATION_TIMEOUT_SECONDS=8

SERVICES_SEARCH_WEBHOOK_URL=http://host.docker.internal:5680/webhook-test/sa-services-search
SERVICES_SEARCH_TIMEOUT_SECONDS=8
